# Django Configuration
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,.onrender.com

# Database Configuration
DATABASE_URL=sqlite:///db.sqlite3
# For production: DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Time Zone
TIME_ZONE=America/Sao_Paulo

# Superuser for bootstrap command
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me

# Notificações por E-mail (Gmail SMTP)
# 1. Ative o 2FA na sua conta Google: https://myaccount.google.com/security
# 2. Gere uma App Password em: https://myaccount.google.com/apppasswords
# 3. Preencha as variáveis abaixo com os dados gerados
EMAIL_HOST_USER=seuemail@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
DEFAULT_FROM_EMAIL=seuemail@gmail.com
BARBEARIA_NOME=Minha Barbearia
